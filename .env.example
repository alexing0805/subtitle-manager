# 监控目录（多个目录用逗号分隔）
WATCH_DIRS=/movies

# 扫描间隔（分钟）
SCAN_INTERVAL=30

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 字幕源配置（多个用逗号分隔）
# 可选: opensubtitles, subhd, zimuku
SUBTITLE_SOURCES=subhd,zimuku

# OpenSubtitles API 配置（可选）
# 注册地址: https://www.opensubtitles.com/en/consumers
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# 是否启用自动下载
AUTO_DOWNLOAD=true

# 文件大小阈值（MB），小于此值的文件跳过
MIN_FILE_SIZE_MB=100

# 最大并发下载数
MAX_CONCURRENT_DOWNLOADS=3

# 下载前是否备份原字幕
BACKUP_EXISTING_SUBTITLE=false
