# 媒体目录
MOVIE_DIR=/movies
TV_DIR=/tvshows
ANIME_DIR=/anime

# 扫描间隔（分钟）
SCAN_INTERVAL=30

# 日志级别 (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# 字幕源配置（按优先级用逗号分隔）
SUBTITLE_SOURCES=shooter,assrt,opensubtitles,subhd

# OpenSubtitles API 配置（可选）
OPENSUBTITLES_API_KEY=
OPENSUBTITLES_USERNAME=
OPENSUBTITLES_PASSWORD=

# TMDB API 配置（推荐）
TMDB_API_KEY=

# 是否启用自动下载
AUTO_DOWNLOAD=true

# 自动下载请求节流（秒）
AUTO_DOWNLOAD_DELAY_MIN_SECONDS=6
AUTO_DOWNLOAD_DELAY_MAX_SECONDS=14

# 文件大小阈值（MB），小于此值的文件跳过
MIN_FILE_SIZE_MB=100

# 最大并发下载数
MAX_CONCURRENT_DOWNLOADS=3

# 下载前是否备份原字幕
BACKUP_EXISTING_SUBTITLE=false

# Plex（可选）
PLEX_SERVER_URL=
PLEX_TOKEN=
PLEX_REFRESH_AFTER_DOWNLOAD=true
PLEX_PATH_MAPPINGS=

# NASTool（可选）
NASTOOL_ENABLED=false
NASTOOL_WEBHOOK_TOKEN=
NASTOOL_PATH_MAPPINGS=
